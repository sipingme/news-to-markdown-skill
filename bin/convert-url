#!/usr/bin/env node

const { NewsToMarkdownConverter } = require('news-to-markdown');
const { parseArgs } = require('node:util');
const { writeFileSync, readFileSync } = require('node:fs');
const { resolve } = require('node:path');

const pkg = JSON.parse(readFileSync(resolve(__dirname, '../package.json'), 'utf-8'));

const { values, positionals } = parseArgs({
  options: {
    url: { type: 'string', short: 'u' },
    output: { type: 'string', short: 'o' },
    'output-dir': { type: 'string', short: 'd' },
    'download-images': { type: 'boolean', default: true },
    'no-download-images': { type: 'boolean', default: false },
    selector: { type: 'string', short: 's' },
    noise: { type: 'string', short: 'n' },
    platform: { type: 'string', short: 'p' },
    'no-metadata': { type: 'boolean', default: false },
    verbose: { type: 'boolean', short: 'v', default: false },
    help: { type: 'boolean', short: 'h', default: false },
  },
  allowPositionals: true,
});

const ARTICLE_URL = values.url || positionals[0];
const OUTPUT = values.output;
const OUTPUT_DIR = values['output-dir'];
const DOWNLOAD_IMAGES = values['no-download-images'] ? false : values['download-images'];
const SELECTOR = values.selector;
const PLATFORM = values.platform;
const NOISE_SELECTORS = values.noise ? values.noise.split(',').map(s => s.trim()) : undefined;
const NO_METADATA = values['no-metadata'];
const VERBOSE = values.verbose;

if (values.help) {
  console.log(`
news-to-markdown-skill v${pkg.version}
ClawHub skill for converting news to markdown

用法: convert-url --url <URL> [选项]

选项:
  --url, -u <URL>        新闻文章的 URL（必需）
  --output, -o <文件>    输出 Markdown 文件路径（默认: stdout）
  --output-dir, -d <目录> 输出目录（用于图片下载）
  --download-images      下载图片到本地（默认开启）
  --no-download-images   不下载图片
  --platform, -p <平台>  指定平台 (toutiao, wechat, xiaohongshu)
  --selector, -s <选择器> CSS 选择器，指定内容区域
  --noise, -n <选择器>   要移除的元素（逗号分隔）
  --no-metadata          不包含元数据（标题、作者、时间）
  --verbose, -v          显示详细日志
  --help, -h             显示帮助信息

示例:
  convert-url --url "https://www.toutiao.com/article/123" --output article.md
  convert-url --url "https://www.toutiao.com/article/123" --download-images --output-dir ./article
  convert-url "https://mp.weixin.qq.com/s/xxx" --platform wechat
  convert-url --url "https://example.com/news" --no-metadata --verbose
`);
  process.exit(0);
}

if (!ARTICLE_URL) {
  console.error('错误: 必须提供 --url 参数');
  console.error('使用 --help 查看帮助');
  process.exit(1);
}

async function main() {
  const startTime = Date.now();

  try {
    const converter = new NewsToMarkdownConverter();
    
    const result = await converter.convert({
      url: ARTICLE_URL,
      platform: PLATFORM,
      selector: SELECTOR,
      noiseSelectors: NOISE_SELECTORS,
      includeMetadata: !NO_METADATA,
      verbose: VERBOSE,
      downloadImages: DOWNLOAD_IMAGES,
      outputDir: OUTPUT_DIR,
    });

    const elapsed = ((Date.now() - startTime) / 1000).toFixed(2);

    if (VERBOSE) {
      console.error(`[INFO] 提取成功 (${elapsed}s)`);
      console.error(`[INFO] 平台: ${result.metadata.platform}`);
      console.error(`[INFO] 抓取方式: ${result.metadata.fetchMethod}`);
      console.error(`[INFO] 标题: ${result.metadata.title || '未知'}`);
      console.error(`[INFO] 作者: ${result.metadata.author || '未知'}`);
      console.error(`[INFO] 发布时间: ${result.metadata.publishTime || '未知'}`);
      console.error(`[INFO] 内容长度: ${result.metadata.contentLength} 字符`);
      console.error(`[INFO] 图片数量: ${result.metadata.imageCount} 张`);
    }

    if (OUTPUT) {
      writeFileSync(OUTPUT, result.markdown, 'utf-8');
      console.error(`✅ 已保存到 ${OUTPUT}`);
    } else {
      console.log(result.markdown);
    }

    if (VERBOSE) {
      console.error(JSON.stringify({
        success: true,
        metadata: result.metadata,
        elapsed: `${elapsed}s`,
      }, null, 2));
    }

  } catch (err) {
    console.error(`❌ 转换失败: ${err.message}`);
    if (VERBOSE) {
      console.error(err.stack);
    }
    process.exit(1);
  }
}

main();
